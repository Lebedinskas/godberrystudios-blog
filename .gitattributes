# Normalize line endings for text files
* text=auto eol=lf

# Hugo content and config
*.md text eol=lf
*.html text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.css text eol=lf
*.js text eol=lf
*.svg text eol=lf

# Keep binary files binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.webp binary
